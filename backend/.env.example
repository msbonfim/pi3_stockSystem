# Copie para .env na mesma pasta (backend/) e preencha.
# O Django carrega .env automaticamente — não precisa de "set" manual no cmd.

METABASE_URL=http://localhost:3000

# Autenticação no Metabase (uma das opções):
# 1) API key (Admin → API keys) — recomendado
METABASE_API_KEY=

# 2) Ou email + senha do utilizador Metabase
# METABASE_USER=
# METABASE_PASSWORD=

# IDs das 6 perguntas guardadas (URL /question/NUMERO)
METABASE_CARD_OVERVIEW=
METABASE_CARD_BY_CATEGORY=
METABASE_CARD_BY_BRAND=
METABASE_CARD_LOW_STOCK=
METABASE_CARD_TOP_VALUE=
METABASE_CARD_EXPIRATION=

# Opcional: se não usar o .bat que já define DATABASE_URL
# DATABASE_URL=postgresql://app:app@127.0.0.1:5432/sistema_gestao
